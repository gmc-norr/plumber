{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/gmc-norr/plumber/blob/schema/plumber-v1.schema.json",
    "title": "plumberfile",
    "description": "plumberfile v1 definition, see https://github.com/gmc-norr/plumber",
    "type": "object",
    "required": ["version", "pipelines"],
    "properties": {
        "version": {
            "description": "plumberfile version",
            "type": "integer",
            "const": 1
        },
        "source": {
            "description": "URI to the original source of the config, only valid for single pipelines",
            "type": "string",
            "format": "uri-reference"
        },
        "revision": {
            "description": "revision of the original source from which the configuration was fetched, only valid for single pipelines",
            "type": "string",
            "format": "uri-reference"
        },
        "pipelines": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["name", "engine", "version"],
                "properties": {
                    "name": {
                        "description": "pipeline name, which should be on the form <org>/<repo>",
                        "type": "string"
                    },
                    "engine": {
                        "description": "pipeline engine",
                        "enum": ["nextflow", "snakemake"]
                    },
                    "executor": {
                        "type": "object",
                        "required": ["name", "version"],
                        "properties": {
                            "name": {
                                "description": "the binary that is used for executing the pipeline",
                                "type": "string"
                            },
                            "version": {
                                "description": "version of the binary that is used for executing the pipeline",
                                "type": "string"
                            }
                        }
                    },
                    "version": {
                        "description": "the pipeline version that this configuration supports",
                        "type": "string"
                    },
                    "environment": {
                        "description": "environment variables to pass to the execution",
                        "type": "object",
                        "patternProperties": {
                            "^[A-Z0-9_]+$": {
                                "type": "string",
                                "minLength": 1
                            }
                        }
                    },
                    "args": {
                        "descriptions": "arguments to pass on the command line",
                        "type": "object",
                        "patternProperties": {
                            "^[A-Za-z0-9_-]+$": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    {
                                        "type": "boolean"
                                    },
                                    {
                                        "type": "array",
                                        "minLength": 1,
                                        "items": {
                                            "oneOf": [
                                                {"type": "string"},
                                                {"type": "number"}
                                            ]
                                        }
                                    }
                                ]
                            }
                        }
                    },
                    "profiles": {
                        "description": "profile definitions that should be available for pipeline execution",
                        "type": "array"
                    },
                    "config_files": {
                        "description": "profile definitions that should be available for pipeline execution",
                        "type": "array",
                        "items": {
                            "description": "relative path to a config file",
                            "type": "string",
                            "format": "uri-reference"
                        }
                    },
                    "param_files": {
                        "description": "parameter files that should be included for pipeline execution",
                        "type": "array",
                        "items": {
                            "description": "relative path to a parameter file",
                            "type": "string",
                            "format": "uri-reference"
                        }
                    },
                    "assets": {
                        "description": "assets that should be available for pipeline execution",
                        "type": "array",
                        "items": {
                            "description": "relative path to asset, either a file or directory",
                            "type": "string",
                            "format": "uri-reference"
                        }
                    }
                },
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "engine": {"const": "snakemake"}
                            }
                        },
                        "then": {
                            "required": ["executor"],
                            "properties": {
                                "profiles": {
                                    "items": {
                                        "description": "snakemake profile specification",
                                        "type": "object",
                                        "required": ["name", "profile", "config_files"],
                                        "properties": {
                                            "name": {
                                                "description": "name of the profile",
                                                "type": "string"
                                            },
                                            "profile": {
                                                "description": "path to the snakemake profile directory",
                                                "type": "string",
                                                "format": "uri-reference"
                                            },
                                            "config_files": {
                                                "description": "array of config files",
                                                "type": "array",
                                                "items": {
                                                    "type": "string",
                                                    "format": "uri-reference"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "engine": {"const": "nextflow"}
                            }
                        },
                        "then": {
                            "properties": {
                                "profiles": {
                                    "items": {
                                        "type": "string",
                                        "format": "uri-reference",
                                        "minLength": 1
                                    }
                                }
                            }
                        }
                    }
                ]
            }
        }
    },
    "dependentRequired": {
        "source": ["revision"],
        "revision": ["source"]
    },
    "dependentSchemas": {
        "source": {
            "properties": {
                "pipelines": {
                    "maxItems": 1
                }
            }
        }
    }
}
